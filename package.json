{
  "name": "passport-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0 <23"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:full": "node scripts/dev.mjs --with-legacy-ai --with-image-enhancer",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "node server/appServer.mjs",
    "dev:legacy-ai": "python -m uvicorn services.legacy.background_removal.main:app --host 127.0.0.1 --port 8787",
    "dev:image-enhancer": "python -m uvicorn services.image_enhancement.main:app --host 127.0.0.1 --port 8788",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/appServer.mjs --serve-dist",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "supabase:start": "npx supabase start",
    "supabase:db:push": "npx supabase db push"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@supabase/supabase-js": "^2.101.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zipcodes": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4"
  }
}
